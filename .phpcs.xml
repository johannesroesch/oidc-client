<?xml version="1.0"?>
<ruleset name="OIDC Client">
    <description>OIDC Client WordPress Plugin – Code Style</description>

    <file>includes</file>
    <file>oidc-client.php</file>

    <!-- WordPress-Sicherheitsregeln – nicht deaktivierbar -->
    <rule ref="WordPress.Security"/>

    <!-- Basis WordPress-Regeln mit Ausnahmen für den bestehenden Stil -->
    <rule ref="WordPress-Core">
        <!-- Plugin verwendet 4-Spaces-Einrückung -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
        <!-- Array-Einrückung nach eigenem Stil -->
        <exclude name="WordPress.Arrays.ArrayIndentation"/>
        <!-- Alignment-Leerzeichen in Arrays (=> Ausrichtung) -->
        <exclude name="WordPress.Arrays.MultipleStatementAlignment"/>
        <exclude name="Generic.Formatting.MultipleStatementAlignment"/>
        <!-- Multi-Line-Funktionsaufrufe: PEAR-Stil nicht erzwingen -->
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
        <!-- Spacing nach Komma im Argument-Alignment -->
        <exclude name="Generic.Functions.FunctionCallArgumentSpacing.TooMuchSpaceAfterComma"/>
        <!-- Precision Alignment -->
        <exclude name="Universal.WhiteSpace.PrecisionAlignment"/>
        <!-- Operator-Spacing bei Alignment -->
        <exclude name="WordPress.WhiteSpace.OperatorSpacing"/>
    </rule>

    <!-- Kommentare: Inline-Kommentar-Format entspannt -->
    <rule ref="Squiz.Commenting.InlineComment">
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.InlineComment.NotCapital"/>
        <exclude name="Squiz.Commenting.InlineComment.SpacingAfter"/>
    </rule>

    <!-- Docblocks: keine fehlenden-Kommentar-Fehler erzwingen -->
    <rule ref="Squiz.Commenting.FunctionComment">
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingReturn"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ScalarTypeHintMissing"/>
        <exclude name="Squiz.Commenting.FunctionComment.TypeHintMissing"/>
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectParamVarName"/>
    </rule>
    <rule ref="Squiz.Commenting.ClassComment">
        <exclude name="Squiz.Commenting.ClassComment.Missing"/>
    </rule>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/wordpress/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>
    <!-- Nur Fehler zählen; Warnings nicht als CI-Blocker -->
    <arg name="warning-severity" value="0"/>
</ruleset>
