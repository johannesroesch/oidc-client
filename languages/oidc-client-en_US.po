#: includes/class-oidc-admin.php
msgid "OIDC Client"
msgstr "OIDC Client"

#: includes/class-oidc-admin.php
msgid "OIDC Client Einstellungen"
msgstr "OIDC Client Settings"

#: includes/class-oidc-admin.php
msgid "Provider"
msgstr "Provider"

#: includes/class-oidc-admin.php
msgid "Gib die Discovery-URL deines OIDC-Providers ein und klicke auf „Abrufen\", um die Endpunkte automatisch zu befüllen."
msgstr "Enter your OIDC provider's discovery URL and click \"Fetch\" to automatically fill in the endpoints."

#: includes/class-oidc-admin.php
msgid "Discovery URL"
msgstr "Discovery URL"

#: includes/class-oidc-admin.php
msgid "Abrufen"
msgstr "Fetch"

#: includes/class-oidc-admin.php
msgid "Provider-Name"
msgstr "Provider Name"

#: includes/class-oidc-admin.php
msgid "Wird im Login-Button angezeigt: „Login mit …\""
msgstr "Displayed in the login button: \"Log in with …\""

#: includes/class-oidc-admin.php
msgid "Issuer"
msgstr "Issuer"

#: includes/class-oidc-admin.php
msgid "Wird automatisch aus der Discovery-URL befüllt."
msgstr "Automatically populated from the discovery URL."

#: includes/class-oidc-admin.php
msgid "Authorization Endpoint"
msgstr "Authorization Endpoint"

#: includes/class-oidc-admin.php
msgid "Token Endpoint"
msgstr "Token Endpoint"

#: includes/class-oidc-admin.php
msgid "Userinfo Endpoint"
msgstr "Userinfo Endpoint"

#: includes/class-oidc-admin.php
msgid "JWKS URI"
msgstr "JWKS URI"

#: includes/class-oidc-admin.php
msgid "PKCE (S256)"
msgstr "PKCE (S256)"

#: includes/class-oidc-admin.php
msgid "PKCE verwenden (empfohlen). Deaktivieren wenn der Provider kein PKCE unterstützt und „invalid_client\"-Fehler auftreten."
msgstr "Use PKCE (recommended). Disable if the provider does not support PKCE and \"invalid_client\" errors occur."

#: includes/class-oidc-admin.php
msgid "Client"
msgstr "Client"

#: includes/class-oidc-admin.php
msgid "Client ID"
msgstr "Client ID"

#: includes/class-oidc-admin.php
msgid "Client Secret"
msgstr "Client Secret"

#: includes/class-oidc-admin.php
msgid "Scopes"
msgstr "Scopes"

#: includes/class-oidc-admin.php
msgid "Leerzeichen-getrennte Liste, z. B. „openid email profile\""
msgstr "Space-separated list, e.g. \"openid email profile\""

#: includes/class-oidc-admin.php
msgid "Redirect URI"
msgstr "Redirect URI"

#: includes/class-oidc-admin.php
msgid "Diese URI muss beim OIDC-Provider als erlaubte Redirect URI eingetragen werden."
msgstr "This URI must be registered as an allowed redirect URI with the OIDC provider."

#: includes/class-oidc-admin.php
msgid "Token-Endpoint Authentifizierung"
msgstr "Token Endpoint Authentication"

#: includes/class-oidc-admin.php
msgid "client_secret_post – Credentials im POST-Body (Standard, z. B. easyVerein, Keycloak)"
msgstr "client_secret_post – Credentials in POST body (default, e.g. easyVerein, Keycloak)"

#: includes/class-oidc-admin.php
msgid "client_secret_basic – HTTP Basic Auth (z. B. Azure AD, Okta)"
msgstr "client_secret_basic – HTTP Basic Auth (e.g. Azure AD, Okta)"

#: includes/class-oidc-admin.php
msgid "Wie sich dieses Plugin beim Token-Endpoint authentifiziert. Bei „invalid_client\"-Fehlern die andere Methode probieren."
msgstr "How this plugin authenticates with the token endpoint. Try the other method if \"invalid_client\" errors occur."

#: includes/class-oidc-admin.php
msgid "Benutzerverwaltung"
msgstr "User Management"

#: includes/class-oidc-admin.php
msgid "Benutzer automatisch anlegen"
msgstr "Automatically create users"

#: includes/class-oidc-admin.php
msgid "Falls kein lokales Konto existiert, wird automatisch eines erstellt."
msgstr "If no local account exists, one will be created automatically."

#: includes/class-oidc-admin.php
msgid "Standard-Rolle für neue Benutzer"
msgstr "Default role for new users"

#: includes/class-oidc-admin.php
msgid "Debug-Modus"
msgstr "Debug Mode"

#: includes/class-oidc-admin.php
msgid "Zeigt bei Fehlern die vollständige Provider-Antwort und gesendete Parameter an. Nur zur Fehlersuche aktivieren, danach wieder deaktivieren."
msgstr "Shows the full provider response and sent parameters on error. Enable for troubleshooting only, then disable again."

#: includes/class-oidc-admin.php
msgid "Erweiterte Optionen"
msgstr "Advanced Options"

#: includes/class-oidc-admin.php
msgid "End-Session Endpoint"
msgstr "End-Session Endpoint"

#: includes/class-oidc-admin.php
msgid "Token-Refresh"
msgstr "Token Refresh"

#: includes/class-oidc-admin.php
msgid "Refresh-Token und Access-Token nach Login speichern und automatisch erneuern."
msgstr "Save refresh and access tokens after login and renew them automatically."

#: includes/class-oidc-admin.php
msgid "Active-Claim"
msgstr "Active Claim"

#: includes/class-oidc-admin.php
msgid "Claim-Name der Aktivierung (z. B. „active\" oder „email_verified\"). Login wird verweigert wenn false/0."
msgstr "Name of the activation claim (e.g. \"active\" or \"email_verified\"). Login is denied if false/0."

#: includes/class-oidc-admin.php
msgid "Profilbild synchronisieren"
msgstr "Sync Profile Picture"

#: includes/class-oidc-admin.php
msgid "Profilbild (picture-Claim) vom Provider übernehmen und als WordPress-Avatar anzeigen."
msgstr "Use the provider's picture claim as the WordPress avatar."

#: includes/class-oidc-admin.php
msgid "WP-Login-Formular ausblenden"
msgstr "Hide WP Login Form"

#: includes/class-oidc-admin.php
msgid "Standard-WordPress-Loginformular ausblenden. Mit ?showlogin=1 weiterhin erreichbar."
msgstr "Hide the default WordPress login form. Still accessible via ?showlogin=1."

#: includes/class-oidc-admin.php
msgid "Auto-Login"
msgstr "Auto Login"

#: includes/class-oidc-admin.php
msgid "Automatisch zum OIDC-Provider weiterleiten wenn die Login-Seite aufgerufen wird."
msgstr "Automatically redirect to the OIDC provider when the login page is loaded."

#: includes/class-oidc-admin.php
msgid "Button-Icon URL"
msgstr "Button Icon URL"

#: includes/class-oidc-admin.php
msgid "Token-Verschlüsselung"
msgstr "Token Encryption"

#: includes/class-oidc-admin.php
msgid "Access-, Refresh- und ID-Token verschlüsselt in der Datenbank speichern (AES-256-CBC). Erfordert PHP OpenSSL."
msgstr "Store access, refresh and ID tokens encrypted in the database (AES-256-CBC). Requires PHP OpenSSL."

#: includes/class-oidc-admin.php
msgid "E-Mail sperren"
msgstr "Lock Email"

#: includes/class-oidc-admin.php
msgid "OIDC-Nutzer können ihre E-Mail-Adresse nicht selbst ändern."
msgstr "OIDC users cannot change their email address."

#: includes/class-oidc-admin.php
msgid "Passwort sperren"
msgstr "Lock Password"

#: includes/class-oidc-admin.php
msgid "OIDC-Nutzer können ihr Passwort nicht selbst ändern."
msgstr "OIDC users cannot change their password."

#: includes/class-oidc-admin.php
msgid "Session-Management"
msgstr "Session Management"

#: includes/class-oidc-admin.php
msgid "Session an Token-Ablauf binden: Bei jedem Request Token prüfen, Refresh versuchen, sonst ausloggen. Erfordert Token-Refresh."
msgstr "Tie session to token expiry: check token on every request, attempt refresh, otherwise log out. Requires token refresh."

#: includes/class-oidc-admin.php
msgid "Angemeldet bleiben"
msgstr "Remember Me"

#: includes/class-oidc-admin.php
msgid "Nie – Sitzung endet beim Schließen des Browsers"
msgstr "Never – Session ends when the browser is closed"

#: includes/class-oidc-admin.php
msgid "Immer – Dauerhaftes Auth-Cookie (14 Tage)"
msgstr "Always – Persistent auth cookie (14 days)"

#: includes/class-oidc-admin.php
msgid "Rollen-Mapping"
msgstr "Role Mapping"

#: includes/class-oidc-admin.php
msgid "Ordne Werte aus dem Rollen-Claim WordPress-Rollen zu. Wird kein Mapping gefunden, bleibt die bestehende Rolle erhalten."
msgstr "Map values from the role claim to WordPress roles. If no mapping is found, the existing role is kept."

#: includes/class-oidc-admin.php
msgid "Rollen-Claim"
msgstr "Role Claim"

#: includes/class-oidc-admin.php
msgid "Name des Claims der Rollen enthält, z. B. „roles\" oder „groups\"."
msgstr "Name of the claim containing roles, e.g. \"roles\" or \"groups\"."

#: includes/class-oidc-admin.php
msgid "Claim-Wert"
msgstr "Claim Value"

#: includes/class-oidc-admin.php
msgid "WordPress-Rolle"
msgstr "WordPress Role"

#: includes/class-oidc-admin.php
msgid "Entfernen"
msgstr "Remove"

#: includes/class-oidc-admin.php
msgid "Einem Claim-Wert können mehrere Zeilen zugewiesen werden. Es wird die erste passende Zeile verwendet."
msgstr "A claim value can have multiple rows. The first matching row is used."

#: includes/class-oidc-admin.php
msgid "+ Zeile hinzufügen"
msgstr "+ Add row"

#: includes/class-oidc-admin.php
msgid "Konfiguration auf OIDC-Provider-Seite"
msgstr "OIDC Provider Configuration"

#: includes/class-oidc-admin.php
msgid "Diese Werte musst du in der Client-Konfiguration deines OIDC-Providers (z. B. Keycloak, Entra ID, Google, easyVerein) hinterlegen."
msgstr "Enter these values in the client configuration of your OIDC provider (e.g. Keycloak, Entra ID, Google, easyVerein)."

#: includes/class-oidc-admin.php
msgid "Parameter"
msgstr "Parameter"

#: includes/class-oidc-admin.php
msgid "Wert"
msgstr "Value"

#: includes/class-oidc-admin.php
msgid "Redirect URI (Callback URL)"
msgstr "Redirect URI (Callback URL)"

#: includes/class-oidc-admin.php
msgid "Post-logout Redirect URI"
msgstr "Post-logout Redirect URI"

#: includes/class-oidc-admin.php
msgid "Backchannel Logout URI"
msgstr "Backchannel Logout URI"

#: includes/class-oidc-admin.php
msgid "Allowed Origin / CORS Origin"
msgstr "Allowed Origin / CORS Origin"

#: includes/class-oidc-admin.php
msgid "Allowed Web Origin"
msgstr "Allowed Web Origin"

#: includes/class-oidc-admin.php
msgid "Initiate Login URI"
msgstr "Initiate Login URI"

#: includes/class-oidc-admin.php
msgid "Kopieren"
msgstr "Copy"

#: includes/class-oidc-admin.php
msgid "JWKS-Cache leeren"
msgstr "Clear JWKS Cache"

